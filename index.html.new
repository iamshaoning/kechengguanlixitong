        <div class="bg-white rounded-lg border border-gray-200 p-6 w-full max-w-md mx-4 no-shadow transform scale-90 opacity-0 translate-y-4 transition-all duration-400" id="modal-content" style="transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);">
            <!-- 模态框内容将通过JavaScript动态生成 -->
        </div>
    </div>

    <!-- 通知提示 -->
    <div id="notification" class="fixed top-4 right-4 bg-white shadow-lg rounded-lg px-6 py-4 transform translate-x-full opacity-0 transition-all-300 z-50 max-w-sm">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <i id="notification-icon" class="fa fa-info-circle text-blue-500 text-xl"></i>
            </div>
            <div class="ml-3 flex-1">
                <h3 id="notification-title" class="text-sm font-medium text-gray-900">通知</h3>
                <div class="mt-1 text-sm text-gray-500">
                    <p id="notification-message">这是一条通知消息</p>
                </div>
            </div>
            <div class="ml-4 flex-shrink-0 flex">
                <button id="notification-close" class="bg-white rounded-md inline-flex text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    <span class="sr-only">关闭</span>
                    <i class="fa fa-times"></i>
                </button>
            </div>
        </div>
    </div>

    <script>
        // 全局状态管理
        const state = {
            students: [],
            courses: [],
            selectedDate: new Date(),
            selectedCourse: null,
            selectedStudent: null,
            currentPage: 'calendar-page',
            user: null
        };

        // 工具函数
        const utils = {
            // 日期格式化
            formatDate(date) {
                return date.toISOString().split('T')[0];
            },
            formatTime(date) {
                return date.toTimeString().split(' ')[0].substring(0, 5);
            },
            formatDateTime(date) {
                return `${this.formatDate(date)} ${this.formatTime(date)}`;
            },
            // 计算两个时间之间的分钟数
            getMinutesBetween(startTime, endTime) {
                const start = new Date(startTime);
                const end = new Date(endTime);
                return (end - start) / (1000 * 60);
            },
            // 生成唯一ID
            generateId() {
                return Date.now().toString(36) + Math.random().toString(36).substr(2);
            },
            // 验证邮箱格式
            validateEmail(email) {
                const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                return re.test(email);
            },
            // 验证密码强度
            validatePassword(password) {
                return password.length >= 6;
            }
        };

        // 通知系统
        const notification = {
            show(message, type = 'info', duration = 3000